# LLM backend. Default: Groq free tier (llama-3.3-70b, 100k tok/day, no card).
# Get a key at https://console.groq.com. Swap provider without code changes.
LLM_PROVIDER=groq
LLM_MODEL=
LLM_RATE_LIMIT_PER_MIN=5
GROQ_API_KEY=
# Alternatives (set LLM_PROVIDER to one of these and fill its key):
#   openai — gpt-4o-mini, paid (~$0.65/mo), no daily cap    -> OPENAI_API_KEY
#   gemini — backend below, extract() only (rollback)
OPENAI_API_KEY=

# Gemini: rollback text backend AND the vision-OCR fallback for scanned
# invoice PDFs (ADR-0010) — vision always uses Gemini regardless of LLM_PROVIDER
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_RATE_LIMIT_PER_MIN=15

DATABASE_PATH=/data/openclaw.db

GMAIL_CREDENTIALS_PATH=/data/credentials.json
GMAIL_TOKEN_PATH=/data/token.json
GMAIL_POLL_INTERVAL_MINUTES=5

PETCOVER_TEMPLATE_PATH=/data/petcover-claim-template.pdf
CLAIM_OUTPUT_DIR=/data/claims
VET_CLAIM_PIPELINE_INTERVAL_MINUTES=15
INVOICE_MATCH_WINDOW_DAYS=3

OWNER_NAME=
OWNER_PHONE=
OWNER_EMAIL=
OWNER_ADDRESS=
OWNER_POSTCODE=
# one of: ACT, NSW, NT, QLD, SA, TAS, VIC, WA (Petcover form's state dropdown)
OWNER_STATE=

# optional: also search invoices forwarded from this address, not just the vet directly
SPOUSE_EMAIL=

# bank account for claim payment section (same account used for every claim)
OWNER_BANK_ACCOUNT_NAME=
OWNER_BANK_BSB=
OWNER_BANK_ACCOUNT_NUMBER=

# ignore Petcover status emails older than this (Gmail after: format, YYYY/MM/DD);
# guards against first-run backfill of historical replies
PETCOVER_STATUS_SINCE=2026/07/18

# Telegram bot (BotFather-issued token). Chat ID is captured automatically the
# first time this username sends /start to the bot — nothing to copy manually.
TELEGRAM_BOT_TOKEN=
TELEGRAM_USERNAME=jagberg
